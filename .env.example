# Arquivo de exemplo para configuração de variáveis de ambiente
# Renomeie para .env e adicione suas chaves de API

# OpenAI API (Para geração de embeddings)
OPENAI_API_KEY=sua-chave-aqui

# Configuração do site
SITE_URL=https://disparorapido.com.br

# API Backend URL (build do site usa essa URL nas chamadas de checkout/auth)
# Local:
VITE_API_URL=http://localhost:3000/api/v1
# Produção (Netlify: definir como variável de ambiente no site):
# VITE_API_URL=https://api.disparorapido.com.br/api/v1

# reCAPTCHA (Frontend)
# Chave do site para reCAPTCHA v2 (https://www.google.com/recaptcha/admin)
VITE_RECAPTCHA_SITE_KEY=sua-chave-publica-aqui
